{
  "name": "shop-mf-cart",
  "version": "0.1.0",
  "description": "Cart Module Federation remote for the Shop MFS demo project.",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.6.0"
  },
  "scripts": {
    "build": "rspack build",
    "dev": "rspack serve --host 0.0.0.0 --port 3002",
    "format": "prettier . --check",
    "format:write": "prettier . --write",
    "lint": "eslint .",
    "preview": "rspack serve --host 0.0.0.0 --port 3002 --mode production",
    "test": "vitest run",
    "test:mf-contracts": "rspack build && vitest run src/module-federation.contract.test.tsx",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hookform/resolvers": "5.4.0",
    "@module-federation/enhanced": "2.5.1",
    "@tanstack/react-query": "5.101.0",
    "@w1zll/shop-ui": "0.2.2",
    "lucide-react": "1.18.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.79.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@rspack/cli": "2.0.8",
    "@rspack/core": "2.0.8",
    "@rspack/dev-server": "2.0.3",
    "@tailwindcss/postcss": "4.3.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "css-loader": "7.1.4",
    "eslint": "10.5.0",
    "jsdom": "29.1.1",
    "postcss": "8.5.6",
    "postcss-loader": "8.2.1",
    "prettier": "3.8.4",
    "style-loader": "4.0.0",
    "tailwindcss": "4.3.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.61.0",
    "vitest": "4.1.8"
  }
}
